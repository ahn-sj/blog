---
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        color: #1f2933;
        background: #f7f7f2;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      body {
        margin: 0;
      }

      a {
        color: #0f766e;
        text-decoration-thickness: 0.08em;
        text-underline-offset: 0.18em;
      }

      .shell {
        width: min(100% - 32px, 760px);
        margin: 0 auto;
        padding: 48px 0 72px;
      }

      header {
        margin-bottom: 40px;
      }

      nav {
        display: flex;
        gap: 16px;
        margin-bottom: 28px;
        font-size: 0.95rem;
      }

      h1 {
        margin: 0 0 12px;
        color: #111827;
        font-size: clamp(2rem, 5vw, 3.5rem);
        line-height: 1.05;
      }

      h2 {
        margin-top: 40px;
        color: #111827;
      }

      p,
      li {
        line-height: 1.75;
      }

      img {
        max-width: 100%;
        height: auto;
        border: 1px solid #d7d7cd;
      }

      .post-list {
        display: grid;
        gap: 18px;
        padding: 0;
        list-style: none;
      }

      .post-list article {
        padding: 20px 0;
        border-top: 1px solid #d7d7cd;
      }

      .post-list h2 {
        margin: 0 0 8px;
        font-size: 1.35rem;
      }

      .muted {
        color: #59636e;
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <nav>
        <a href="/">홈</a>
        <a href="/blog/">글</a>
      </nav>
      <slot />
    </main>
  </body>
</html>
